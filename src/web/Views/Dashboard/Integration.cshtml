@model IntegrationViewModel
@{
    ViewData["Title"] = "Integration Health";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-plug"></i> Integration Health</h2>
    <a asp-action="Integration" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow mb-4">
            <div class="card-header @(Model.KeyVaultConnected ? "bg-success" : "bg-danger") text-white">
                <i class="bi bi-key"></i> Azure Key Vault
                <span class="badge bg-light text-dark float-end">
                    @(Model.KeyVaultConnected ? "Connected" : "Disconnected")
                </span>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr>
                            <th style="width: 40%">Vault Name</th>
                            <td>@Model.KeyVaultName</td>
                        </tr>
                        <tr>
                            <th>Access Method</th>
                            <td>Managed Identity (DefaultAzureCredential)</td>
                        </tr>
                        <tr>
                            <th>Demo Secret</th>
                            <td>
                                @if (Model.KeyVaultConnected)
                                {
                                    <code>@Model.DemoSecretValue</code>
                                }
                                else
                                {
                                    <span class="text-danger">
                                        <i class="bi bi-exclamation-triangle"></i> @Model.KeyVaultError
                                    </span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td>
                                @if (Model.KeyVaultConnected)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Healthy</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Failed</span>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow mb-4">
            <div class="card-header @(Model.SqlConnected ? "bg-success" : "bg-danger") text-white">
                <i class="bi bi-database"></i> Azure SQL Database
                <span class="badge bg-light text-dark float-end">
                    @(Model.SqlConnected ? "Connected" : "Disconnected")
                </span>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <tbody>
                        <tr>
                            <th style="width: 40%">Auth Method</th>
                            <td>Managed Identity (Entra / AAD)</td>
                        </tr>
                        <tr>
                            <th>User Count</th>
                            <td>
                                @if (Model.SqlConnected)
                                {
                                    <span class="badge bg-info">@Model.SqlUserCount users</span>
                                }
                                else
                                {
                                    <span class="text-danger">N/A</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Status</th>
                            <td>
                                @if (Model.SqlConnected)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle"></i> Healthy</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Failed</span>
                                    <br /><small class="text-danger">@Model.SqlError</small>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.AppGatewayUrl))
{
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow mb-4">
                <div class="card-header bg-info text-white">
                    <i class="bi bi-shield-check"></i> Application Gateway (WAF)
                </div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <tbody>
                            <tr>
                                <th style="width: 20%">Gateway URL</th>
                                <td><a href="@Model.AppGatewayUrl" target="_blank">@Model.AppGatewayUrl</a></td>
                            </tr>
                            <tr>
                                <th>WAF Mode</th>
                                <td><span class="badge bg-warning text-dark">Prevention</span></td>
                            </tr>
                            <tr>
                                <th>Rule Set</th>
                                <td>OWASP 3.2</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

<div class="row mt-3">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-warning">
                <i class="bi bi-lightning-charge"></i> SRE Chaos Scenarios
            </div>
            <div class="card-body">
                <p>Use the Function App chaos API to trigger integration failures that SRE Agent can detect:</p>
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Scenario</th>
                            <th>Trigger</th>
                            <th>Expected Impact</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Key Vault Access Lost</strong></td>
                            <td><code>POST /api/revoke-keyvault-access</code></td>
                            <td>Web App cannot read secrets — this page shows Key Vault as <span class="badge bg-danger">Disconnected</span></td>
                        </tr>
                        <tr>
                            <td><strong>SQL Database Access Lost</strong></td>
                            <td><code>POST /api/revoke-sql-access</code></td>
                            <td>Web App cannot connect to SQL — this page shows SQL as <span class="badge bg-danger">Disconnected</span></td>
                        </tr>
                        <tr>
                            <td><strong>WAF SQL Injection Block</strong></td>
                            <td><code>POST /api/trigger-waf-sql-injection</code></td>
                            <td>App Gateway WAF blocks SQL injection patterns — visible in WAF logs</td>
                        </tr>
                    </tbody>
                </table>
                <p class="text-muted mb-0"><small>Restore access with <code>POST /api/restore-keyvault-access</code> and <code>POST /api/restore-sql-access</code></small></p>
            </div>
        </div>
    </div>
</div>
