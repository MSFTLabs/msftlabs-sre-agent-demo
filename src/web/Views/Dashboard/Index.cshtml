@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-speedometer2"></i> Dashboard</h2>
    <span class="badge bg-success fs-6">Welcome, @ViewBag.DisplayName</span>
</div>

<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body text-center">
                <i class="bi bi-hdd-stack display-4"></i>
                <h5 class="mt-2">Memory</h5>
                <p class="display-6">@Model.MemoryUsageMB MB</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body text-center">
                <i class="bi bi-clock-history display-4"></i>
                <h5 class="mt-2">Uptime</h5>
                <p class="display-6">@Model.ProcessUptime.ToString(@"d\.hh\:mm")</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-body text-center">
                <i class="bi bi-cpu display-4"></i>
                <h5 class="mt-2">Threads</h5>
                <p class="display-6">@Model.ThreadCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body text-center">
                <i class="bi bi-people display-4"></i>
                <h5 class="mt-2">Users</h5>
                <p class="display-6">@Model.TotalUsers</p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-server"></i> System Information
            </div>
            <div class="card-body">
                <table class="table table-striped mb-0">
                    <tbody>
                        <tr>
                            <th>Server Name</th>
                            <td>@Model.ServerName</td>
                        </tr>
                        <tr>
                            <th>Environment</th>
                            <td>
                                <span class="badge @(Model.EnvironmentName == "Production" ? "bg-danger" : "bg-info")">
                                    @Model.EnvironmentName
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th>.NET Runtime</th>
                            <td>@Model.RuntimeVersion</td>
                        </tr>
                        <tr>
                            <th>Server Time (UTC)</th>
                            <td>@Model.CurrentTimeUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-person-badge"></i> Session Information
            </div>
            <div class="card-body">
                <table class="table table-striped mb-0">
                    <tbody>
                        <tr>
                            <th>Username</th>
                            <td>@User.Identity?.Name</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</td>
                        </tr>
                        <tr>
                            <th>Login Time</th>
                            <td>@ViewBag.LoginTime</td>
                        </tr>
                        <tr>
                            <th>Session Cookie</th>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
