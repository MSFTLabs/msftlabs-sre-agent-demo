@{
    ViewData["Title"] = "Admin - SRE Agent Demo";
}

<h2 class="mb-4">SRE Agent Demo &mdash; Incident Trigger</h2>
<p class="text-muted">Simulate a SQL injection attack against the Application Gateway WAF. The WAF blocks the malicious requests, generating firewall logs and triggering Azure Monitor alerts that the SRE Agent automatically investigates.</p>

<div id="statusAlert" class="alert d-none" role="alert"></div>

<div class="row justify-content-center mt-4">
    <div class="col-md-8 col-lg-6">
        <div class="card border-danger shadow">
            <div class="card-header bg-danger text-white text-center fs-5">
                <i class="bi bi-shield-exclamation me-2"></i>SQL Injection Attack Simulation
            </div>
            <div class="card-body text-center p-4">
                <p class="card-text mb-2">This sends SQL injection patterns through the Application Gateway. The WAF (OWASP 3.2 Prevention mode) blocks the requests, generating firewall logs and triggering Azure Monitor alerts.</p>
                <hr />
                <p class="card-text text-muted small mb-3">
                    <strong>What happens:</strong><br/>
                    1. SQL injection payloads sent to App Gateway<br/>
                    2. WAF blocks requests (HTTP 403)<br/>
                    3. <em>WAF Blocked Requests</em> alert fires (Sev 2)<br/>
                    4. SRE Agent picks up the incident and investigates
                </p>
                <button id="triggerBtn" class="btn btn-danger btn-lg w-100">
                    <i class="bi bi-shield-exclamation me-2"></i>Trigger SQL Injection Attack
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('triggerBtn').addEventListener('click', function () {
        var btn = this;
        var alertEl = document.getElementById('statusAlert');
        var originalHtml = btn.innerHTML;

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Running...';

        fetch('@Url.Action("TriggerSqlInjection", "Admin")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            }
        })
        .then(function (r) {
            return r.text().then(function (txt) {
                try { var d = JSON.parse(txt); } catch (_) { d = { message: r.ok ? 'Done' : 'Error ' + r.status }; }
                return { ok: r.ok, data: d };
            });
        })
        .then(function (result) {
            var d = result.data;
            if (result.ok && d.blockedCount !== undefined) {
                alertEl.className = 'alert alert-success';
                alertEl.textContent = 'SQL injection test complete: ' + d.blockedCount + '/' + d.totalPatterns + ' patterns blocked by WAF. Alert should fire within ~2 minutes.';
            } else if (d.error) {
                alertEl.className = 'alert alert-warning';
                alertEl.textContent = 'Error: ' + d.error;
            } else {
                alertEl.className = result.ok ? 'alert alert-success' : 'alert alert-warning';
                alertEl.textContent = JSON.stringify(d);
            }
            alertEl.classList.remove('d-none');
        })
        .catch(function (err) {
            alertEl.className = 'alert alert-danger';
            alertEl.textContent = 'Request failed: ' + err.message;
            alertEl.classList.remove('d-none');
        })
        .finally(function () {
            btn.disabled = false;
            btn.innerHTML = originalHtml;
            location.href = '#statusAlert';
        });
    });
</script>
}

@Html.AntiForgeryToken()
