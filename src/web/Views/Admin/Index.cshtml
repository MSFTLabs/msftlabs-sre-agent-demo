@{
    ViewData["Title"] = "Admin - Chaos Triggers";
    var functionAppUrl = ViewBag.FunctionAppUrl as string ?? "";
}

<h2 class="mb-4">Chaos Engineering Triggers</h2>
<p class="text-muted">Use these controls to inject faults into the demo environment. Each trigger calls the Function App chaos API and generates telemetry for Azure SRE Agent to detect and diagnose.</p>

@if (string.IsNullOrEmpty(functionAppUrl))
{
    <div class="alert alert-warning">
        <strong>FunctionAppUrl not configured.</strong> Set the <code>FunctionAppUrl</code> app setting to enable chaos triggers. Buttons will POST to relative paths which require the Function App URL.
    </div>
}

<div id="statusAlert" class="alert d-none" role="alert"></div>

<div class="row g-4 mt-2">
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-danger">
            <div class="card-header bg-danger text-white">Application Errors</div>
            <div class="card-body">
                <p class="card-text">Trigger unhandled exceptions to test Application Insights exception tracking and alerting.</p>
                <button class="btn btn-outline-danger w-100 chaos-btn" data-endpoint="trigger-exception" data-body='{"type":"NullReference"}'>
                    <i class="bi bi-bug me-1"></i>Trigger Exception
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-warning">
            <div class="card-header bg-warning">Performance Degradation</div>
            <div class="card-body">
                <p class="card-text">Inject artificial latency to test slow-response detection and performance alerts.</p>
                <button class="btn btn-outline-warning w-100 chaos-btn" data-endpoint="trigger-slow-response" data-body='{"delay_seconds":10}'>
                    <i class="bi bi-hourglass-split me-1"></i>Trigger Slow Response
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-danger">
            <div class="card-header bg-danger text-white">Resource Exhaustion</div>
            <div class="card-body">
                <p class="card-text">Allocate large memory blocks to simulate memory leaks and resource pressure.</p>
                <button class="btn btn-outline-danger w-100 chaos-btn" data-endpoint="trigger-memory-leak" data-body='{"size_mb":50}'>
                    <i class="bi bi-memory me-1"></i>Trigger Memory Leak
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-warning">
            <div class="card-header bg-warning">CPU Saturation</div>
            <div class="card-body">
                <p class="card-text">Generate CPU-intensive workloads to test compute scaling and performance degradation.</p>
                <button class="btn btn-outline-warning w-100 chaos-btn" data-endpoint="trigger-cpu-spike" data-body='{"duration_seconds":15}'>
                    <i class="bi bi-cpu me-1"></i>Trigger CPU Spike
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-danger">
            <div class="card-header bg-danger text-white">Dependency Failure</div>
            <div class="card-body">
                <p class="card-text">Simulate downstream service unavailability to validate circuit breaker detection.</p>
                <button class="btn btn-outline-danger w-100 chaos-btn" data-endpoint="trigger-dependency-failure">
                    <i class="bi bi-link-45deg me-1"></i>Trigger Dependency Failure
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="card h-100 border-warning">
            <div class="card-header bg-warning">Log Flood</div>
            <div class="card-body">
                <p class="card-text">Produce a burst of error log entries to test log pipeline capacity and anomaly detection.</p>
                <button class="btn btn-outline-warning w-100 chaos-btn" data-endpoint="trigger-log-flood" data-body='{"count":100}'>
                    <i class="bi bi-file-earmark-text me-1"></i>Trigger Log Flood
                </button>
            </div>
        </div>
    </div>
</div>

<h3 class="mt-5 mb-3">Access Control Chaos</h3>
<p class="text-muted">These actions modify Azure RBAC role assignments. Use Revoke to break access, then Restore to repair it.</p>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100 border-dark">
            <div class="card-header bg-dark text-white">Key Vault Access</div>
            <div class="card-body">
                <p class="card-text">Revoke or restore the web app managed identity's Key Vault Secrets User role assignment.</p>
                <div class="d-flex gap-2">
                    <button class="btn btn-danger flex-fill chaos-btn" data-endpoint="revoke-keyvault-access">
                        <i class="bi bi-lock me-1"></i>Revoke
                    </button>
                    <button class="btn btn-success flex-fill chaos-btn" data-endpoint="restore-keyvault-access">
                        <i class="bi bi-unlock me-1"></i>Restore
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 border-dark">
            <div class="card-header bg-dark text-white">SQL Database Access</div>
            <div class="card-body">
                <p class="card-text">Revoke or restore the web app managed identity's SQL Contributor role assignment.</p>
                <div class="d-flex gap-2">
                    <button class="btn btn-danger flex-fill chaos-btn" data-endpoint="revoke-sql-access">
                        <i class="bi bi-lock me-1"></i>Revoke
                    </button>
                    <button class="btn btn-success flex-fill chaos-btn" data-endpoint="restore-sql-access">
                        <i class="bi bi-unlock me-1"></i>Restore
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<h3 class="mt-5 mb-3">WAF Testing</h3>
<div class="row g-4">
    <div class="col-md-6">
        <div class="card h-100 border-info">
            <div class="card-header bg-info text-white">SQL Injection via WAF</div>
            <div class="card-body">
                <p class="card-text">Send SQL injection patterns through the Application Gateway to validate WAF blocking and log generation.</p>
                <button class="btn btn-outline-info w-100 chaos-btn" data-endpoint="trigger-waf-sql-injection">
                    <i class="bi bi-shield-exclamation me-1"></i>Trigger WAF SQL Injection Test
                </button>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 border-info">
            <div class="card-header bg-info text-white">Error Storm</div>
            <div class="card-body">
                <p class="card-text">Generate a rapid burst of errors across multiple categories to stress test monitoring and alerting.</p>
                <button class="btn btn-outline-info w-100 chaos-btn" data-endpoint="trigger-error-storm" data-body='{"count":50}'>
                    <i class="bi bi-lightning me-1"></i>Trigger Error Storm
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.chaos-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var endpoint = this.getAttribute('data-endpoint');
            var body = this.getAttribute('data-body') || '{}';
            var baseUrl = '@Html.Raw(functionAppUrl)';
            var url = baseUrl ? baseUrl.replace(/\/+$/, '') + '/api/' + endpoint : '/api/' + endpoint;
            var alert = document.getElementById('statusAlert');

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Running...';

            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: body
            })
            .then(function (r) { return r.json().then(function (d) { return { ok: r.ok, data: d }; }); })
            .then(function (result) {
                alert.className = result.ok ? 'alert alert-success' : 'alert alert-warning';
                alert.textContent = endpoint + ': ' + (result.data.message || JSON.stringify(result.data));
                alert.classList.remove('d-none');
            })
            .catch(function (err) {
                alert.className = 'alert alert-danger';
                alert.textContent = endpoint + ' failed: ' + err.message;
                alert.classList.remove('d-none');
            })
            .finally(function () {
                btn.disabled = false;
                btn.innerHTML = btn.getAttribute('data-original-html') || btn.textContent;
                location.href = '#statusAlert';
            });

            btn.setAttribute('data-original-html', btn.innerHTML);
        });
    });
</script>
}
