{
  "name": "SRE Agent Demo",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "8.0"
    }
  },
  "postCreateCommand": "curl -fsSL https://aka.ms/install-azd.sh | bash && dotnet restore src/web/SreDemo.Web.csproj",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-bicep",
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ms-azuretools.vscode-azureappservice",
        "ms-vscode.azurecli",
        "yzhang.markdown-all-in-one"
      ],
      "settings": {
        "dotnet.defaultSolution": "src/web/SreDemo.Web.csproj"
      }
    }
  },
  "forwardPorts": [5000, 5001],
  "portsAttributes": {
    "5000": { "label": "Web App (HTTP)" },
    "5001": { "label": "Web App (HTTPS)" }
  }
}